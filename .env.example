POSTGRES_DB=fitness_app
POSTGRES_USER=fitness_user
POSTGRES_PASSWORD=fitness_password
POSTGRES_PORT=5432

BACKEND_ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DOCS_ENABLED=true
BACKEND_DATABASE_ECHO=false
BACKEND_DATABASE_URL=postgresql+asyncpg://fitness_user:fitness_password@localhost:5432/fitness_app
# Optional: set this only if Alembic should use a different sync URL.
# BACKEND_ALEMBIC_DATABASE_URL=postgresql+psycopg://fitness_user:fitness_password@localhost:5432/fitness_app
# Local-only sample secret. Use your own 32+ character value outside local development.
BACKEND_AUTH_SECRET_KEY=development-auth-secret-change-me-before-production-use
BACKEND_AUTH_ACCESS_TOKEN_EXPIRE_SECONDS=43200
BACKEND_AUTH_PASSWORD_RESET_TOKEN_EXPIRE_SECONDS=3600
BACKEND_AUTH_EMAIL_VERIFICATION_TOKEN_EXPIRE_SECONDS=86400
BACKEND_CORS_ALLOWED_ORIGINS=[]
BACKEND_CORS_ALLOW_CREDENTIALS=true
# Optional: override the default localhost CORS regex if needed.
# BACKEND_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$
